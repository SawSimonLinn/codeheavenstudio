# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ADMIN_EMAIL=admin@example.com
ADMIN_AUTH_SECRET=replace-with-a-long-random-secret

# Optional Supabase object names
SUPABASE_RECEIPTS_TABLE=receipts
SUPABASE_ADMIN_AUDIT_TABLE=admin_audit_logs
SUPABASE_NEXT_RECEIPT_COUNTER_RPC=next_receipt_counter

# Email / SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
SMTP_PASS=your_app_password
EMAIL_FROM=Code Heaven Studio <you@example.com>

# AI
GEMINI_API_KEY=your_google_ai_api_key
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_key

# Optional: one-time import from Appwrite -> Supabase
APPWRITE_ENDPOINT=https://your-appwrite-instance/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key
APPWRITE_DATABASE_ID=your_appwrite_database_id
APPWRITE_RECEIPTS_COLLECTION_ID=receipts
APPWRITE_COUNTERS_COLLECTION_ID=counters
APPWRITE_ADMIN_AUDIT_COLLECTION_ID=admin_audit_logs
